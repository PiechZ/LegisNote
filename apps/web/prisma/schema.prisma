// LegisNote Prisma schema.
//
// IMPORTANT: the AUTHORITATIVE database schema is infra/db/schema.sql (applied by
// the postgres container on first init). It uses Postgres features Prisma cannot
// fully express (ltree, generated tsvector columns, citext, custom FTS config).
//
// This file is a STARTER mirror so `prisma generate` works and the app type-checks.
// After `pnpm db:up`, run `pnpm --filter @legisnote/web db:pull` to regenerate the
// full, exact schema by introspection. Special columns appear as `Unsupported(...)`.

generator client {
  provider      = "prisma-client-js"
  // "native" for local dev; the Debian target is bundled for the Docker image
  // (node:20-slim is Debian bookworm → openssl 3.x).
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum NodeType {
  law
  part
  title
  chapter
  section
  paragraph
  point
  sentence
  span

  @@map("node_type")
}

enum AnchorStatus {
  ok
  shifted
  orphaned

  @@map("anchor_status")
}

enum AnnotationScope {
  shared
  personal

  @@map("annotation_scope")
}

enum SnapshotStatus {
  draft
  published

  @@map("snapshot_status")
}

enum UserRole {
  reader
  editor
  admin

  @@map("user_role")
}

enum LinkKind {
  reference
  cross_law
  definition
  related
  amends
  see_also
  custom

  @@map("link_kind")
}

model AppUser {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email           String   @unique // citext in DB
  displayName     String   @map("display_name")
  passwordHash    String?  @map("password_hash")
  role            UserRole @default(reader)
  anthropicKeyEnc Bytes?   @map("anthropic_key_enc")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @default(now()) @map("updated_at") @db.Timestamptz()

  @@map("app_user")
}

model Law {
  id                String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  citation          String
  number            String
  year              Int
  titleCs           String         @map("title_cs")
  shortTitle        String?        @map("short_title")
  sourceKind        String?        @map("source_kind")
  currentSnapshotId String?        @map("current_snapshot_id") @db.Uuid
  metadata          Json           @default("{}")
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  snapshots         LawSnapshot[]  @relation("LawSnapshots")
  nodes             StructuralNode[]
  anchors           Anchor[]

  @@unique([number, year])
  @@map("law")
}

model LawSnapshot {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lawId         String         @map("law_id") @db.Uuid
  seq           Int
  effectiveFrom DateTime       @map("effective_from") @db.Date
  effectiveTo   DateTime?      @map("effective_to") @db.Date
  amendingAct   String?        @map("amending_act")
  amendingMeta  Json           @default("{}") @map("amending_meta")
  sourceCommit  String?        @map("source_commit")
  status        SnapshotStatus @default(draft)
  importedAt    DateTime       @default(now()) @map("imported_at") @db.Timestamptz()
  law           Law            @relation("LawSnapshots", fields: [lawId], references: [id], onDelete: Cascade)
  units         SnapshotUnit[]

  @@unique([lawId, seq])
  @@unique([lawId, effectiveFrom])
  @@map("law_snapshot")
}

model StructuralNode {
  id                  String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lawId               String         @map("law_id") @db.Uuid
  nodeType            NodeType       @map("node_type")
  nodeKey             String?        @map("node_key")
  firstSeenSnapshotId String?        @map("first_seen_snapshot_id") @db.Uuid
  supersededByNodeId  String?        @map("superseded_by_node_id") @db.Uuid
  createdAt           DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  law                 Law            @relation(fields: [lawId], references: [id], onDelete: Cascade)
  units               SnapshotUnit[]
  anchors             Anchor[]

  @@unique([lawId, nodeKey])
  @@map("structural_node")
}

model SnapshotUnit {
  id           String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  snapshotId   String                @map("snapshot_id") @db.Uuid
  nodeId       String                @map("node_id") @db.Uuid
  parentUnitId String?               @map("parent_unit_id") @db.Uuid
  nodeType     NodeType              @map("node_type")
  label        String?
  ordinal      Int
  path         Unsupported("ltree")
  text         String?
  textHash     Bytes?                @map("text_hash")
  fts          Unsupported("tsvector")?
  metadata     Json                  @default("{}")
  snapshot     LawSnapshot           @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  node         StructuralNode        @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@unique([snapshotId, nodeId])
  @@map("snapshot_unit")
}

// --- Annotation overlay (FR-3/4/5/6) ----------------------------------------
// Anchors are the addressable seam; annotations/comments/tags/links attach to
// them. v1 is the shared/canonical layer (scope=shared, ownerId=NULL); the
// per-user layer flips on ownerId in v2 (FR-7). Whole-unit anchors have a NULL
// selector; range/term anchors (selector jsonb) are a later increment.

model Anchor {
  id                  String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lawId               String         @map("law_id") @db.Uuid
  nodeId              String         @map("node_id") @db.Uuid
  selector            Json?
  createdInSnapshotId String?        @map("created_in_snapshot_id") @db.Uuid
  anchorStatus        AnchorStatus   @default(ok) @map("anchor_status")
  createdAt           DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  law                 Law            @relation(fields: [lawId], references: [id], onDelete: Cascade)
  node                StructuralNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  annotations         Annotation[]
  comments            Comment[]
  tagAssignments      TagAssignment[]
  linksFrom           Link[]         @relation("LinkSrc")
  linksTo             Link[]         @relation("LinkDst")
  examHighlights      ExamHighlight[]
  userHighlights      UserHighlight[]

  @@map("anchor")
}

model Annotation {
  id        String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  anchorId  String                  @map("anchor_id") @db.Uuid
  scope     AnnotationScope         @default(shared)
  ownerId   String?                 @map("owner_id") @db.Uuid
  authorId  String?                 @map("author_id") @db.Uuid
  body      Json
  bodyFts   Unsupported("tsvector")? @map("body_fts")
  createdAt DateTime                @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime                @default(now()) @map("updated_at") @db.Timestamptz()
  anchor    Anchor                  @relation(fields: [anchorId], references: [id], onDelete: Cascade)

  @@map("annotation")
}

model Comment {
  id        String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  anchorId  String          @map("anchor_id") @db.Uuid
  parentId  String?         @map("parent_id") @db.Uuid
  scope     AnnotationScope @default(shared)
  ownerId   String?         @map("owner_id") @db.Uuid
  authorId  String?         @map("author_id") @db.Uuid
  body      String
  createdAt DateTime        @default(now()) @map("created_at") @db.Timestamptz()
  anchor    Anchor          @relation(fields: [anchorId], references: [id], onDelete: Cascade)
  parent    Comment?        @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[]       @relation("CommentThread")

  @@map("comment")
}

model Tag {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  scope       AnnotationScope @default(shared)
  ownerId     String?         @map("owner_id") @db.Uuid
  name        String
  color       String?
  assignments TagAssignment[]

  @@unique([scope, ownerId, name])
  @@map("tag")
}

model TagAssignment {
  tagId      String   @map("tag_id") @db.Uuid
  anchorId   String   @map("anchor_id") @db.Uuid
  assignedBy String?  @map("assigned_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  anchor     Anchor   @relation(fields: [anchorId], references: [id], onDelete: Cascade)

  @@id([tagId, anchorId])
  @@map("tag_assignment")
}

model Link {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  srcAnchorId String          @map("src_anchor_id") @db.Uuid
  dstAnchorId String          @map("dst_anchor_id") @db.Uuid
  kind        LinkKind        @default(reference)
  directed    Boolean         @default(true)
  scope       AnnotationScope @default(shared)
  ownerId     String?         @map("owner_id") @db.Uuid
  label       String?
  metadata    Json            @default("{}")
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz()
  src         Anchor          @relation("LinkSrc", fields: [srcAnchorId], references: [id], onDelete: Cascade)
  dst         Anchor          @relation("LinkDst", fields: [dstAnchorId], references: [id], onDelete: Cascade)

  @@map("link")
}

// --- Study aids (FR-11/12/13) -----------------------------------------------
// Exams + admin-curated highlights ("this § appears in Exam X", D9) anchored to
// stable nodes so they survive amendments. UserHighlight is the personal layer.

model Exam {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  createdBy   String?         @map("created_by") @db.Uuid
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz()
  highlights  ExamHighlight[]

  @@map("exam")
}

model ExamHighlight {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  examId    String   @map("exam_id") @db.Uuid
  anchorId  String   @map("anchor_id") @db.Uuid
  note      String?
  weight    Int?
  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  anchor    Anchor   @relation(fields: [anchorId], references: [id], onDelete: Cascade)

  @@unique([examId, anchorId])
  @@map("exam_highlight")
}

model UserHighlight {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  anchorId  String   @map("anchor_id") @db.Uuid
  color     String?
  note      String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  anchor    Anchor   @relation(fields: [anchorId], references: [id], onDelete: Cascade)

  @@unique([userId, anchorId])
  @@map("user_highlight")
}

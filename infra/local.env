# Dev-only defaults for the LOCAL stack (docker-compose.local.yml), loaded via
# `--env-file local.env`. Passing this file explicitly also stops Compose from
# auto-loading infra/.env, so the local stack is deterministic regardless of any
# production secrets you keep there.
#
# THROWAWAY CREDENTIALS — never use these anywhere real.
POSTGRES_USER=legisnote
POSTGRES_PASSWORD=localdev
POSTGRES_DB=legisnote
AUTH_SECRET=dev-only-auth-secret-not-for-production
IMPORTER_TOKEN=dev-importer-token

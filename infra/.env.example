# Copy to infra/.env and fill in. NEVER commit infra/.env (see .gitignore).

# --- PostgreSQL (source of truth, D6) ---
POSTGRES_USER=legisnote
POSTGRES_PASSWORD=change-me
POSTGRES_DB=legisnote

# --- Reverse proxy / TLS ---
# Your real domain on the VPS (Caddy auto-provisions TLS). Leave as localhost for
# local runs (plain HTTP). DNS A/AAAA records must point at the VPS first.
LEGISNOTE_DOMAIN=localhost

# --- Web app ---
# Inside Docker the app reaches Postgres at host `postgres`; compose builds this
# DATABASE_URL from the POSTGRES_* values above, so this line is only used when
# running the app OUTSIDE Docker (local dev → localhost).
DATABASE_URL=postgres://legisnote:change-me@localhost:5432/legisnote
AUTH_SECRET=generate-with-openssl-rand-base64-32
# Bearer token the ingestion importer presents to POST /api/import. Must match
# LEGISNOTE_IMPORTER_TOKEN used by tools/ingestion. Generate: openssl rand -hex 32
IMPORTER_TOKEN=change-me-too

# --- MinIO (S3-compatible object storage: source PDFs, exports) ---
MINIO_ROOT_USER=legisnote
MINIO_ROOT_PASSWORD=change-me

# --- Meilisearch (v2) ---
MEILI_MASTER_KEY=

# --- Ingestion secrets (consumed by tools/ingestion) ---
# D10: your own Anthropic Claude API key — only the PDF-fallback structure pass uses it.
ANTHROPIC_API_KEY=
# D11: eSbírka REST API key — obtained later from the Ministry of Interior; leave blank for now.
ESBIRKA_API_KEY=
# zakonyprolidi.cz partner key (optional fallback source).
ZAKONYPROLIDI_API_KEY=
# FR-24/D6: git backup mirror of the clean Markdown. Path to a dedicated git
# working tree (e.g. a clone of a backup remote). Leave blank to skip mirroring
# (avoids committing into the app repo by accident). Set _PUSH=1 to push after commit.
LEGISNOTE_GIT_MIRROR_DIR=
LEGISNOTE_GIT_MIRROR_PUSH=

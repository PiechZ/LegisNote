# Copy to infra/.env and fill in. NEVER commit infra/.env (see .gitignore).

# --- PostgreSQL (source of truth, D6) ---
POSTGRES_USER=legisnote
POSTGRES_PASSWORD=change-me
POSTGRES_DB=legisnote

# --- Web app ---
# Used by Prisma/the app to reach Postgres. For local dev outside Docker use localhost.
DATABASE_URL=postgres://legisnote:change-me@localhost:5432/legisnote
AUTH_SECRET=generate-with-openssl-rand-base64-32

# --- MinIO (S3-compatible object storage: source PDFs, exports) ---
MINIO_ROOT_USER=legisnote
MINIO_ROOT_PASSWORD=change-me

# --- Meilisearch (v2) ---
MEILI_MASTER_KEY=

# --- Ingestion secrets (consumed by tools/ingestion) ---
# D10: your own Anthropic Claude API key — only the PDF-fallback structure pass uses it.
ANTHROPIC_API_KEY=
# D11: eSbírka REST API key — obtained later from the Ministry of Interior; leave blank for now.
ESBIRKA_API_KEY=
# zakonyprolidi.cz partner key (optional fallback source).
ZAKONYPROLIDI_API_KEY=
